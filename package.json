{
  "name": "paypal-mcp-server",
  "version": "1.0.0",
  "private": true,
  "description": "Remote MCP server (Streamable HTTP) exposing PayPal Sandbox payment tools for a Salesforce Agentforce demo",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "eslint": "^9.29.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.1.10"
  }
}
